# .env.local (copy this file and fill in your values)
# ──────────────────────────────────────────────────────────────────────────────
# DO NOT commit this file to Git – it's in .gitignore already
# ──────────────────────────────────────────────────────────────────────────────

# ── Firebase Admin SDK (server-side) ─────────────────────────────────────────
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app

# ── Firebase Client SDK (browser-side, safe to expose) ───────────────────────
# Get from Firebase Console → Project Settings → Your Apps → Web App → Config
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyAjcW1VzJTR0vK-hhVMLIzURaxVdc9bn_w
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=smart-farm-app-17a42.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://smart-farm-app-17a42-default-rtdb.asia-south1.firebasedatabase.app
NEXT_PUBLIC_FIREBASE_PROJECT_ID=smart-farm-app-17a42
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=smart-farm-app-17a42.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=663927605279
NEXT_PUBLIC_FIREBASE_APP_ID=1:663927605279:web:2b9c4c53377dd5fa642d2a

# ── Twilio (for SMS location requests to SIM800L) ────────────────────────────
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+12345678901   # your Twilio number

# ── Anthropic Claude (chatbot) ────────────────────────────────────────────────
# Get from https://console.anthropic.com
GEMINI_API_KEY=AIzaSyDqzz9ITi9Ip09wEYYhpVQgYwisw3HJsaI 

# ── Hardware security ─────────────────────────────────────────────────────────
# A random secret string shared between this server and the SIM800L firmware.
# Generate: openssl rand -hex 32
# Must also be set in smart_farm.ino as HARDWARE_SECRET
HARDWARE_SHARED_SECRET=your_random_64_char_hex_string_here
